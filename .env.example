# ITER MVP — Environment Configuration

# Supabase Configuration (Get these from your Supabase project settings)
# Project Settings → API → URL + Keys
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database Connection (Direct Postgres connection)
# Project Settings → Database → Connection String → URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# Rust Server Configuration
RUST_LOG=info
RUST_BACKTRACE=1
SERVER_PORT=8080

# Flutter Configuration
# (These are read at runtime, not build time)

# Map tile source (MapLibre vector tiles). Default OpenFreeMap is free and
# requires no API key. Override to switch to Stadia Maps / MapTiler if needed.
# See srs/06-geo-logic.md and ADR-005 in ralph/DECISIONS.md.
MAP_TILE_URL=https://tiles.openfreemap.org/styles/liberty

# Optional: only set if you switch the tile source to a provider that requires
# an API key (Stadia, MapTiler, etc.). Leave empty for OpenFreeMap.
MAP_TILE_API_KEY=
